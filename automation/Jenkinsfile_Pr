def common_funcs
def samples1 = ['le_periph_blps' , 'le_periph_cgms' , 'le_periph_cpps', 'le_periph_cscps' , 'le_periph_mics' , 'le_periph_vcp' ]
def samples2 = ['le_central_batt', 'le_periph'      , 'le_periph_batt', 'le_periph_blinky', 'le_multiprofile', 'le_periph_ots' ]
def samples3 = ['le_periph_glps' , 'le_periph_hello', 'le_periph_hr'  , 'le_periph_htpt'  , 'le_periph_anps' , 'le_periph_pacs']
def samples4 = ['le_periph_past' , 'le_periph_plxp' , 'le_periph_pm'  , 'le_periph_prxp'  , 'le_throughput'  , 'le_periph_ccp' ]
def samples5 = ['le_periph_rscps', 'le_periph_ws'   , 'mesh_light_bulb','smp_svr'         , 'le_periph_haps' , 'le_periph_tips']
def samples6 = ['auracast'       , 'broadcast_mode_switch','unicast_acceptor','unicast_initiator']
def samples7 = ['testapp']

def all_ble_samples = [ [baseDir: 'samples/bluetooth', samples: samples1], [baseDir: 'samples/bluetooth',    samples: samples2],
    [baseDir: 'samples/bluetooth',    samples: samples3], [baseDir: 'samples/bluetooth', samples: samples4],
    [baseDir: 'samples/bluetooth', samples: samples5], [baseDir: 'samples/bluetooth/le_audio', samples: samples6],
    [baseDir: 'applications', samples: samples7]
]

def testAppList1 = [
    ['I2C' , 'samples/drivers/i2c_dw -S alif-dk'], ['LPI2C' , 'samples/drivers/lpi2c'], ['CRC' , 'samples/drivers/crc'],
    ['ADC' , 'samples/drivers/adc -S alif-adc' ], ['DAC', 'samples/drivers/dac']
]
def testAppList2 = [
    ['HelloWorld' , '../zephyr/samples/hello_world'], ['EchoBot' , '../zephyr/samples/drivers/uart/echo_bot'],
    ['Blinky' , '../zephyr/samples/basic/blinky' ], ['Entropy', '../zephyr/tests/drivers/entropy/api'],
    ['Input_Dump', '../zephyr/samples/subsys/input/input_dump -S alif-ak-dk']
]

def gAllRecipientEmails     = ""
def gAlif_all_boards_list   = []
def allTestApps             = [testAppList1, testAppList2]


pipeline {
    agent any
    options {
        disableConcurrentBuilds(abortPrevious: true)
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    common_funcs = load 'automation/ble_samples.groovy'
                }
            }
        }
        stage('verify_checkpatch') {
            agent { label 'zas20' }
            options { skipDefaultCheckout() }
            steps {
                script {
                    common_funcs.verify_checkpatch()
                }
            }
        }
        stage('verify_gitlint') {
            agent { label 'zas20' }
            options { skipDefaultCheckout() }
            steps {
                script {
                    common_funcs.verify_gitlint()
                }
            }
        }
        stage('Pr_Build For Parallel') {
            agent { label 'zas20' }
            steps {
                script {
                    def parallelStages = [:]
                    all_ble_samples.eachWithIndex { group, idx ->
                        def stageName = "BLE samples stage ${idx + 1}"
                        parallelStages[stageName] = {
                            stage(stageName) {
                                node('zas20') {
                                    try {
                                        common_funcs.initialize()
                                        group.samples.each { sample ->
                                            echo "Building sample: ${sample}"
                                            common_funcs.build_ble(
                                                "${group.baseDir}/${sample}",
                                                "build-b1-${sample}",
                                                "alif_b1_dk/ab1c1f4m51820ph0/rtss_he"
                                            )
                                        }

                                        // Equivalent of post { success {} }
                                        archiveArtifacts(artifacts: '*.tar', fingerprint: true, allowEmptyArchive: true
                                        )
                                    } catch (Exception e) {
                                        echo "❌ ${stageName} failed"
                                        throw e
                                    } finally {
                                        echo "Completed ${stageName}"
                                    }
                                }
                            }
                        }
                    }
                    parallel parallelStages
                }
            }
        }
        stage('Get-alif-all-board-list') {
            agent { label 'zas20' }
            options { skipDefaultCheckout() }
            steps {
                script {
                    gAlif_all_boards_list = common_funcs.get_all_alif_boards()
                    gAlif_all_boards_list.eachWithIndex { board, idx ->
                        echo "Board_No._${idx} -> '${board}'"
                    }
                }
            }
        }
        stage('Build all samples') {
            agent { label 'zas20' }
            steps {
                script {
                    allTestApps.eachWithIndex { testAppList, idx ->
                        echo "🚩 Running Test App Group ${idx + 1}"
                        try {
                            def buildDeviceStatus = common_funcs.build_test_apps(gAlif_all_boards_list, testAppList)
                            if (!buildDeviceStatus || buildDeviceStatus.isEmpty()) {
                                error "❌ build_test_apps returned empty stages!"
                            }
                            echo "✅ Generated ${buildDeviceStatus.size()} stages."
                            parallel buildDeviceStatus
                            archiveArtifacts(artifacts: '*.tar', fingerprint: true, allowEmptyArchive: true)
                        } catch (err) {
                            error "❌ Failed Test App Group ${idx + 1}: ${err}"
                        }
                    }
                }
            }
        }

        stage('Pr_Flash and test for parallel') {
            parallel {
                stage('Flash&Test_testapp') {
                    agent { label 'lasse' }
                    steps {
                        script {
                            unstash name: 'build-b1-testapp.bin'
                            common_funcs.flash_test()
                            common_funcs.test('tests')
                        }
                    }
                    post {
                        success {
                            archiveArtifacts artifacts: 'automation/pytest/pytest-logs/**', fingerprint: true
                            }
                        }
                }
                stage('Flash&Test_throughput') {
                    agent { label 'AB1' }
                    steps {
                        script {
                            unstash name: 'build-b1-le_throughput.bin'
                            common_funcs.flash_test()
                            common_funcs.test('tests/throughbut_between_two_devices.py')
                        }
                    }
                    post {
                        success {
                            archiveArtifacts artifacts: 'automation/pytest/pytest-logs/**', fingerprint: true
                            }
                        }
                }
            }
        }
    }
    post {
        always{
            recordIssues(
                tools: [gcc()],
                qualityGates: [[threshold: 1, type: 'NEW', failure: true]],
                enabledForFailure: true
            )
        }
    }
}
